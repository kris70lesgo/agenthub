# Web (only NEXT_PUBLIC_* values are exposed to the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CASPER_NETWORK=casper-test
NEXT_PUBLIC_CASPER_NODE_URL=https://node.testnet.casper.network/rpc
NEXT_PUBLIC_CSPR_CLOUD_URL=https://api.testnet.cspr.cloud
NEXT_PUBLIC_AGENT_REGISTRY_CONTRACT_HASH=
NEXT_PUBLIC_CASPER_PUBLIC_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# API
APP_ENV=development
APP_NAME=AgentHub API
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database / Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub@localhost:5432/agenthub
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# AI provider
AI_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.6
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Casper / CSPR.cloud (server-side)
CASPER_NETWORK_NAME=casper-test
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_PUBLIC_KEY=
CASPER_WALLET_PUBLIC_KEY=
CASPER_SECRET_KEY_PATH=
CASPER_DEPLOY_SIGNING_MODE=local-key
CASPER_SIGNED_TRANSACTION_PATH=
CASPER_WALLET_SIGNER_PORT=4177
CASPER_DEPLOY_PAYMENT_AMOUNT=800000000000
CASPER_GAS_PRICE_TOLERANCE=1
AGENTHUB_REGISTRY_PACKAGE_HASH_KEY=agenthub_registry_package_hash
AGENTHUB_REGISTRY_ALLOW_KEY_OVERRIDE=false
AGENTHUB_REGISTRY_IS_UPGRADABLE=true
AGENTHUB_REGISTRY_IS_UPGRADE=false
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=
AGENT_REGISTRY_CONTRACT_HASH=
AGENT_REGISTRY_CONTRACT_PACKAGE_HASH=

# OAuth placeholders
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
